	;; Wasm Maze Zip = 10343 bytes
    (data (i32.const 3088)
		"\50\4B\03\04\14\00\00\00\08\00\ED\04\CC\5C\9F\43\8C\E6\B5\27\00\00\D0\AD\05\00\0E\00\1C\00\77\61\73\6D\5F\6D\61\7A\65\2E\68\74\6D\6C\55\54\09\00\03\BD\E4\2A\6A\58\06\2E\6A\75\78\0B\00\01\04\E8\03\00\00\04\E8\03\00\00\ED\9D\6B\77\DB\B8\B5\86\BF\E7\57\A8\39\EB\34\4E\1B\3B\BA\D9\B2\D3\38\EB\78\12\67\9A\76\32\97\64\D2\99\9E\AE\AE\B3\68\89\B2\D5\D1\C5\95\E8\C4\6E\3B\FF\FD\50\24\6D\6D\19"
