(module
	(memory (export "memory") 1) ;; 65,536 bytes | 65,536 字节

	;; Render background.
	(func $render_background (local $color i32) (local $i i32)
	    ;; Set init value for $color.
		i32.const 2056
		i32.load
		local.set $color
	    ;; Set init value for $i.
	    i32.const 0
		local.set $i

		loop $loop_i
		    ;; Find the memory address to set color info
		    local.get $i
		    i32.const 4
			i32.mul
			local.get $color
			i32.store
			;; increment $i by 1 and see if $i < 384
			local.get $i
			i32.const 1
			i32.add
			local.tee $i
			i32.const 512
			i32.lt_u
			br_if $loop_i
		end
	)

	;; Render foreground.
	(func $render_sprite
		(param $img   i32) (param $dx  i32)
		(local $color i32) (local $i   i32) (local $j  i32)
	    ;; Set init value for $color.
		i32.const 2060
		i32.load
		local.set $color
	    ;; Set init value for $i.
		i32.const 0
		local.set $i

		loop $loop_i
		    ;; Set init value for $j.
		    i32.const 0
			local.set $j

			loop $loop_j
				;; check to see if pixel index is 0 or 1.
				local.get $img ;; img_mem_address
				i32.const 8
				local.get $i   ;; representing y axis
				i32.mul
				local.get $j   ;; representing x axis
				i32.add
				i32.add
				i32.load8_u    ;; get single byte value
				i32.const 1    
				i32.eq         ;; if value is 1 render pixel
				if
					;; dy
					local.get $i
					i32.const 64
					i32.mul
					;; dx
					local.get $j
					local.get $dx
					i32.add
					i32.add
					i32.const 4
					i32.mul
					;; set pixel
					local.get $color
					i32.store
				end
				;; increment $j by 1 and see if $j < 8
				local.get $j
				i32.const 1
				i32.add
				local.tee $j
				i32.const 8
				i32.lt_u
				br_if $loop_j	
			end
			;; increment $i by 1 and see if $i < 8
			local.get $i
			i32.const 1
			i32.add
			local.tee $i
			i32.const 8
			i32.lt_u
			br_if $loop_i	
		end
	)

	(func $render_wat_bird
		;; render frame depending on tick
		i32.const 2050
		i32.load8_u
		i32.const 29
		i32.lt_u
		if (result i32)
			i32.const 2064 ;; img_addr
		else
			i32.const 2128 ;; img_addr
		end
		i32.const 0    ;; dx
		call $render_sprite
	)

	(func $render_hour (local $hour i32)
		i32.const 2048
		i32.load8_u
		;; check to see if hour 0
		local.tee $hour
		i32.const 0
		i32.eq
		if
			i32.const 2256
			i32.const 8
			call $render_sprite
			i32.const 2320
			i32.const 16
			call $render_sprite
		else
			local.get $hour
			i32.const 12
			i32.gt_u
			if
				local.get $hour
				i32.const 12
				i32.sub
				;; last digit
				local.tee $hour
				i32.const 10
				i32.rem_u
				i32.const 64
				i32.mul
				i32.const 2192
				i32.add
				i32.const 16
				call $render_sprite
			else
				;; last digit
				local.get $hour
				i32.const 10
				i32.rem_u
				i32.const 64
				i32.mul
				i32.const 2192
				i32.add
				i32.const 16
				call $render_sprite
			end
			local.get $hour
			i32.const 10
			i32.div_u
			i32.const 10
			i32.rem_u
			i32.const 0
			i32.ne
			if
				local.get $hour
				i32.const 10
				i32.div_u
				i32.const 10
				i32.rem_u
				i32.const 64
				i32.mul
				i32.const 2192
				i32.add
				i32.const 8
				call $render_sprite
			end
		end
	)

	(func $render_symbol_colon
	    i32.const 2051
		i32.load8_u
		i32.const 59
		i32.lt_u
		if
			i32.const 2832 ;; img_addr
			i32.const 24   ;; dx
			call $render_sprite
		end
	)

	(func $render_minute (local $minute i32)
		i32.const 2049
		i32.load8_u

		local.tee $minute
		i32.const 10
		i32.div_u
		i32.const 10
		i32.rem_u
		i32.const 64
		i32.mul
		i32.const 2192
		i32.add
		i32.const 32
		call $render_sprite

		local.get $minute
		i32.const 10
		i32.rem_u
		i32.const 64
		i32.mul
		i32.const 2192
		i32.add
		i32.const 40
		call $render_sprite
	)

	(func $render_am_pm
	    i32.const 2048
		i32.load8_u
		i32.const 12
		i32.lt_u
		if (result i32)
			i32.const 2896 ;; img_addr
		else
			i32.const 2960
		end
		i32.const 48   ;; dx
		call $render_sprite
		i32.const 3024 ;; img_addr
		i32.const 56   ;; dx
		call $render_sprite
	)

	(func $tick_60 (local $tick i32)
		i32.const 2050
		i32.const 2050
		i32.load8_u
		local.tee $tick
		i32.const 59
		i32.lt_u
		if (result i32)
			local.get $tick
			i32.const 1
			i32.add
		else
			i32.const 0
		end
		i32.store8
	)

	(func $tick_120 (local $tick i32)
		i32.const 2051
		i32.const 2051
		i32.load8_u
		local.tee $tick
		i32.const 119
		i32.lt_u
		if (result i32)
			local.get $tick
			i32.const 1
			i32.add
		else
			i32.const 0
		end
		i32.store8
	)

	;; Render current state.
	;; 渲染当前状态。
	(func (export "render")
		call $render_background
		call $render_wat_bird
		call $render_hour
		call $render_symbol_colon
		call $render_minute
		call $render_am_pm
		call $tick_60
		call $tick_120
	)

	;; Bytes 0 - 2047 reserved for virtual video buffer.
	;; 字节  0 - 2047 保留用于虚拟视频缓冲区。

	;; clock_data = 8 bytes | 时钟数据 = 8 字节
	(data (i32.const 2048)
		"\00" ;; Hour     | 小时
		"\00" ;; Minute   | 分钟
		"\00" ;; tick_60 | tick_256（滴答）是指每一帧都会发生变化的值
		"\00" ;; tick_120

		;; RESERVED | 保留
		"\00" ;; reserved | 保留
		"\00" ;; reserved | 保留
		"\00" ;; reserved | 保留
		"\00" ;; reserved | 保留
	)
	 
	;; color_data_RGBA = 8 bytes | 颜色数据RGBA = 8 字节
	(data (i32.const 2056)
		"\E0\E0\E0\FF" ;; background | 背景
		"\65\4F\F0\FF" ;; foreground | 前景
	)
     
	;; image_data = 1024 bytes | 图像数据 = 1024 字节
	(data (i32.const 2064)
	    ;; wat_bird_f0 | 鸟动画帧00
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\01\00\00\00\00"
		"\00\00\01\01\01\01\00\00"
		"\00\01\00\00\00\00\01\00"
		"\00\01\00\01\00\01\01\00"
		"\01\01\00\01\00\01\01\01"
		"\01\01\00\00\01\00\01\01"
		"\00\01\01\01\01\01\01\00"
		"\00\00\01\00\00\00\00\00"
		;; wat_bird_f1 | 鸟动画帧01
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\01\00\00\00"
		"\00\00\01\01\01\01\00\00"
		"\00\01\00\00\00\00\01\00"
		"\00\01\01\00\01\00\01\00"
		"\00\01\01\00\01\00\01\00"
		"\01\01\00\01\00\00\01\01"
		"\01\01\01\01\01\01\01\01"
		"\00\00\00\00\00\01\00\00"
		;; num_0 | 数字0 
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\00\00\00\00"
		"\00\01\01\01\01\01\01\00"
		"\00\01\01\00\00\01\01\00"
		"\00\01\01\00\00\01\01\00"
		"\00\01\01\00\00\01\01\00"
		"\00\01\01\00\00\01\01\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\00\00\00\00"
		;; num_1 | 数字1
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\00\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\01\01\00\00\00"
		"\00\00\00\00\00\00\00\00"
		;; num_2 | 数字2
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\00\00\00\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\01\01\01\00"
		"\00\00\00\00\01\01\01\00"
		"\00\01\01\01\01\01\01\00"
		"\00\01\01\01\00\00\00\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\00\00\00\00"
		;; num_3 | 数字3
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\00\00\00\00"
		"\00\01\01\01\01\01\01\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\00\01\01\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\00\01\01\00"
		"\00\01\01\01\01\01\01\00"
		"\00\00\00\00\00\00\00\00"
		;; num_4 | 数字4
	    ;; 8x8 = 64 bytes | 64 字节
		"\00\00\00\00\00\00\00\00"
		"\00\01\00\00\00\01\01\00"
